# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# Never commit .env to GitHub — it is in .gitignore

# NVIDIA API key — free tier at https://build.nvidia.com
NVIDIA_API_KEY=your_nvidia_api_key_here

# LLM model overrides (optional — defaults below are all FREE-tier models)
# Do NOT change to paid models (nemotron, llama-3.1-405b, mixtral-large)
LLM_FAST=meta/llama-3.1-8b-instruct
LLM_WRITER=meta/llama-3.1-70b-instruct
LLM_CRITIC=meta/llama-3.1-70b-instruct

# Qdrant Cloud (https://cloud.qdrant.io) — optional, enables memory across sessions
# Format: https://xxxxx.us-east-1-0.ts.cloud.qdrant.io:6333
QDRANT_URL=your_qdrant_cloud_url_here
QDRANT_API_KEY=your_qdrant_api_key_here
